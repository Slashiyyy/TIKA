<div class="reviews-section section section--{{ section.settings.section_width }}">
  <div class="page-width">
    <div class="reveal">
      <h2 class="reviews-section__title">{{ section.settings.title }}</h2>
      <p class="faq-section__subtitle" style="text-align:center;">{{ section.settings.subtitle }}</p>
    </div>

    <div class="reviews-grid reveal stagger-reveal">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars">
            {%- assign rating = block.settings.rating | default: 5 -%}
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 20 20" fill="{% if i <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/>
              </svg>
            {%- endfor -%}
          </div>
          <div class="review-card__text">{{ block.settings.text }}</div>
          <div class="review-card__author">{{ block.settings.author }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Reviews",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real reviews from real customers"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "Amazing quality and fit! The fabric feels premium and the design is exactly what I was looking for."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Verified Customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "category": "Premium",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Incredible quality and attention to detail. The oversized fit is perfect and the material feels luxurious.",
            "author": "Alex M."
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Fast shipping and the pieces look exactly like the photos. Already planning my next order.",
            "author": "Jordan K."
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "text": "Great quality for the price. The minimalist aesthetic is exactly what I wanted for my wardrobe.",
            "author": "Sam T."
          }
        }
      ]
    }
  ]
}
{% endschema %}
