
<div class="premium-finale" style="{% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');{% endif %} background-color: {{ section.settings.bg_color }};">
  <div class="premium-finale__bg" style="{% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');{% endif %}"></div>
  <div class="premium-finale__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="premium-finale__content page-width">
    {% if section.settings.subtitle != blank %}
      <span class="premium-finale__subtitle reveal">{{ section.settings.subtitle }}</span>
    {% endif %}
    {% if section.settings.title != blank %}
      <h2 class="premium-finale__title reveal">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="premium-finale__text reveal">{{ section.settings.text }}</p>
    {% endif %}
    {% if section.settings.btn_label != blank and section.settings.btn_link != blank %}
      <a href="{{ section.settings.btn_link }}" class="premium-finale__btn button reveal">{{ section.settings.btn_label }}</a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Premium Finale",
  "class": "premium-finale-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Final Touch"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Built for the bold"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Premium streetwear crafted for those who dare to stand out."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Premium Finale",
      "settings": {
        "title": "Built for the bold",
        "subtitle": "Final Touch",
        "text": "Premium streetwear crafted for those who dare to stand out.",
        "btn_label": "Explore Collection"
      }
    }
  ]
}
{% endschema %}
