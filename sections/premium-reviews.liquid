
<div class="premium-reviews-section" style="{% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');{% endif %} background-color: {{ section.settings.bg_color }};">
  <div class="premium-reviews__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; background: {{ section.settings.overlay_color }};"></div>

  <div class="premium-reviews page-width">
    {% if section.settings.heading != blank %}
      <div class="premium-reviews__header reveal">
        <h2 class="premium-reviews__title">{{ section.settings.heading }}</h2>
        {% if section.settings.subtitle != blank %}
          <p class="premium-reviews__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="premium-reviews__track" dir="ltr">
      {%- for block in section.blocks -%}
        {%- assign rating = block.settings.rating | default: 5 -%}
        {%- assign delay = forloop.index0 | modulo: 5 -%}
        {%- assign float_delay = forloop.index0 | modulo: 4 -%}
        <div class="premium-reviews__card reveal" style="transition-delay: {{ delay | times: 0.12 }}s; --float-delay: {{ float_delay }}s;" {{ block.shopify_attributes }}>
          <div class="premium-reviews__card-inner">
            <div class="premium-reviews__stars">
              {%- for i in (1..5) -%}
                <svg viewBox="0 0 20 20" fill="{% if i <= rating %}#d4a853{% else %}#ddd{% endif %}" width="16" height="16">
                  <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/>
                </svg>
              {%- endfor -%}
            </div>
            <p class="premium-reviews__text">{{ block.settings.review_text }}</p>
            <div class="premium-reviews__customer">
              <div class="premium-reviews__avatar">{{ block.settings.customer_name | slice: 0 }}</div>
              <div>
                <span class="premium-reviews__name">{{ block.settings.customer_name }}</span>
                <span class="premium-reviews__badge">✓ Verified Customer</span>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {% if section.settings.show_review_form %}
      <div class="premium-reviews__form-area reveal">
        <h3 class="premium-reviews__form-heading">{{ section.settings.form_heading }}</h3>
        <p class="premium-reviews__form-subtitle">{{ section.settings.form_subtitle }}</p>
        <button class="premium-reviews__form-btn button" id="premiumReviewFormBtn">{{ section.settings.form_btn_label }}</button>
      </div>
    {% endif %}
  </div>
</div>

{% if section.settings.show_review_form %}
<div class="premium-review-overlay" id="premiumReviewOverlay">
  <div class="premium-review-form">
    <button class="premium-review-form__close" id="premiumReviewFormClose" aria-label="Close">&times;</button>
    <h3 class="premium-review-form__title">{{ section.settings.form_heading }}</h3>
    <form id="premiumReviewForm" novalidate>
      <div class="premium-review-form__field">
        <input type="text" id="premiumReviewName" name="name" placeholder="{{ section.settings.form_name_placeholder }}" required>
      </div>
      <div class="premium-review-form__field">
        <label class="premium-review-form__label">{{ section.settings.form_rating_label }}</label>
        <div class="premium-review-form__stars" id="premiumReviewStars">
          {%- for i in (1..5) -%}
            <svg class="premium-review-form__star" data-rating="{{ i }}" viewBox="0 0 20 20" width="32" height="32" fill="none" stroke="#d4a853" stroke-width="1">
              <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/>
            </svg>
          {%- endfor -%}
        </div>
      </div>
      <div class="premium-review-form__field">
        <textarea id="premiumReviewText" name="review" rows="4" placeholder="{{ section.settings.form_text_placeholder }}" required></textarea>
      </div>
      <div class="premium-review-form__field">
        <div class="premium-review-form__upload">
          <input type="file" id="premiumReviewPhoto" name="photo" accept="image/*">
          <label for="premiumReviewPhoto">{{ section.settings.form_upload_label }}</label>
          <span class="premium-review-form__file-name" id="premiumReviewFileName"></span>
        </div>
      </div>
      <button type="submit" class="premium-review-form__submit button">{{ section.settings.form_submit_label }}</button>
    </form>
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Premium Reviews",
  "class": "premium-reviews-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "color",
