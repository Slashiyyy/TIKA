      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ما يقوله عملاؤنا"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "تجارب حقيقية من عملائنا الكرام"
    },
    {
      "type": "header",
      "content": "Review Form"
    },
    {
      "type": "checkbox",
      "id": "show_review_form",
      "label": "Show review form",
      "default": true
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "شاركنا رأيك"
    },
    {
      "type": "text",
      "id": "form_subtitle",
      "label": "Form subtitle",
      "default": "نود معرفة تجربتك مع منتجاتنا"
    },
    {
      "type": "text",
      "id": "form_btn_label",
      "label": "Form button label",
      "default": "اترك تقييمك"
    },
    {
      "type": "text",
      "id": "form_name_placeholder",
      "label": "Name placeholder",
      "default": "الاسم"
    },
    {
      "type": "text",
      "id": "form_rating_label",
      "label": "Rating label",
      "default": "التقييم"
    },
    {
      "type": "text",
      "id": "form_text_placeholder",
      "label": "Review placeholder",
      "default": "اكتب تقييمك"
    },
    {
      "type": "text",
      "id": "form_upload_label",
      "label": "Upload label",
      "default": "إضافة صورة"
    },
    {
      "type": "text",
      "id": "form_submit_label",
      "label": "Submit label",
      "default": "إرسال التقييم"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "جودة رائعة والتوصيل سريع. أنصح الجميع بتجربة المنتج."
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name",
          "default": "عميل"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Reviews",
      "settings": {
        "heading": "ما يقوله عملاؤنا",
        "subtitle": "تجارب حقيقية من عملائنا الكرام"
      },
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "review_text": "كاليتي هايلة الله يبارك، متوقعتهاش هكا 😍", "customer_name": "أحمد" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "والله كيما التصاور كيما الصح، خدمة نضيفة.", "customer_name": "سارة" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "القماش يبان بلي مليح، والفيت جا كيفاش كنت حاب.", "customer_name": "كريم" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "وصلني بسرعة والباكينغ كان فور ❤️", "customer_name": "مريم" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "بصح يستاهل كل دينار، إن شاء الله نعاود نطلب.", "customer_name": "لطفي" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "القياس جا صحيح 100%، ما احتجتش نبدلو.", "customer_name": "نادية" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "أحسن من بزاف البراندات لي جربتهم.", "customer_name": "عمر" } },
