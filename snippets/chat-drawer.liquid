{% doc %}
  Chat Drawer

  Renders a theme-drawer host for `<shopify-chat>`. The markup is always
  present — when the Inbox app is installed it registers the custom element
  and the chat activates. Without Inbox the element is inert.

  Also renders a premium AI assistant chatbot.

  @example
  {% render 'chat-drawer' %}
{% enddoc %}

<theme-drawer id="chat-drawer">
  <dialog
    ref="panel"
    class="theme-drawer__dialog chat-drawer"
  >
    <shopify-chat
      mode="standalone"
      mode-switch
    ></shopify-chat>
  </dialog>
</theme-drawer>

<!-- Premium AI Chat Assistant -->
<button class="chat-assistant-fab" aria-label="Open chat assistant">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
</button>

<div class="chat-panel">
  <div class="chat-panel__header">
    <span class="chat-panel__header-title">AI Stylist</span>
    <button class="chat-panel__header-close" aria-label="Close chat">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <div class="chat-panel__messages"></div>
  <div class="chat-panel__input">
    <input type="text" placeholder="Ask anything..." aria-label="Type your message">
    <button aria-label="Send message">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </div>
</div>

<script type="module">
  // Shopify Inbox chat logic
  const chatDrawer = document.querySelector('#chat-drawer');
  const shopifyChat = document.querySelector('shopify-chat');

  if (chatDrawer && shopifyChat) {
    document.addEventListener('theme-drawer:open', (event) => {
      if (/** @type {Element} */ (event.target).id !== 'chat-drawer') return;
      shopifyChat?.setAttribute('mode', 'managed');
    });

    document.addEventListener('theme-drawer:close', (event) => {
      if (/** @type {Element} */ (event.target).id !== 'chat-drawer') return;
      if (shopifyChat?.getAttribute('mode') === 'managed') {
        shopifyChat?.removeAttribute('open');
      }
      shopifyChat?.setAttribute('mode', 'standalone');
    });

    document.addEventListener('shopify-chat:enter-managed', () => {
      const isStandaloneAndOpen = shopifyChat?.hasAttribute('open') && shopifyChat?.getAttribute('mode') === 'standalone';
      queueMicrotask(() => {
        if (!shopifyChat?.hasAttribute('open') && !chatDrawer?.hasAttribute('open')) return;
        chatDrawer?.open?.(isStandaloneAndOpen ? { enter: 'inline-start' } : undefined);
      });
    });

    document.addEventListener('shopify-chat:enter-standalone', () => {
      shopifyChat?.setAttribute('mode', 'standalone');
      chatDrawer?.close?.();
    });

    document.addEventListener('shopify-chat:close', () => {
      if (shopifyChat?.getAttribute('mode') === 'managed') chatDrawer?.close?.();
    });

    document.addEventListener('megaMenu:hover', () => {
      if (shopifyChat?.hasAttribute('open') && shopifyChat?.getAttribute('mode') === 'standalone') {
        shopifyChat?.removeAttribute('open');
      }
    });

    customElements.whenDefined('shopify-chat').then(() => {
      const mode = chatDrawer?.hasAttribute('open') ? 'managed' : 'standalone';
      if (shopifyChat?.getAttribute('mode') !== mode) {
        if (mode === 'standalone' && shopifyChat?.hasAttribute('open')) shopifyChat?.removeAttribute('open');
        shopifyChat?.setAttribute('mode', mode);
      }
    });
  }
</script>

{% stylesheet %}
  shopify-chat {
    --shopify-chat-breakpoint: 768px;
  }

  shopify-chat[mode='managed'] {
    position: static;
    height: 100%;
  }

  .theme-drawer__dialog:has(shopify-chat[mode='standalone'][open]) {
    z-index: calc(var(--layer-menu-drawer) + 1);
  }

  .theme-drawer__dialog.chat-drawer:has(shopify-chat:defined) {
    display: flex;
  }
{% endstylesheet %}
